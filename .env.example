# ============================================================
# .env.example — Copy this file to .env on your Linux server
# NEVER commit the real .env file to Git
# ============================================================

# Number of Uvicorn workers (2 * CPU cores + 1 is a good rule)
WORKERS=4

# Port the container exposes
APP_PORT=8000

# Environment label
APP_ENV=production

# Java backend API URLs (change only if the Java team gives a new URL)
INVOICE_API_URL=https://api-bi-buysell-service-ind.u-clo.com/owner-0.0.1/api/Reports/invoice
SALES_API_URL=https://api-bi-buysell-service-ind.u-clo.com/owner-0.0.1/api/Reports/sales
